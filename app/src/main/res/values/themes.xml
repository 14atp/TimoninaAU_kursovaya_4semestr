<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.GuidBuild" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#4b5320</item>
        <item name="colorPrimaryVariant">#3a4218</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#b5b8b1</item>
        <item name="colorSecondaryVariant">#8a8d85</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:colorBackground">@android:color/white</item>
        <item name="android:textColor">@android:color/black</item>

        <item name="android:editTextStyle">@style/EditTextStyle</item>
    </style>

    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textColorHint">#888888</item>
        <item name="android:background">@android:drawable/editbox_background</item>
    </style>

    <style name="CircleImageStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>